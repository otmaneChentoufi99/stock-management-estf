<?xml version="1.0" encoding="UTF-8"?>
<jasperReport
        xmlns="http://jasperreports.sourceforge.net/jasperreports"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://jasperreports.sourceforge.net/jasperreports
        http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
        name="InventoryLabel38x25"

        pageWidth="108"
        pageHeight="71"

        columnWidth="108"
        leftMargin="0"
        rightMargin="0"
        topMargin="0"
        bottomMargin="0">

    <!-- PARAMETERS -->
    <parameter name="inventoryNumber" class="java.lang.String"/>
    <parameter name="designation" class="java.lang.String"/>
    <parameter name="date" class="java.lang.String"/>
    <parameter name="year" class="java.lang.String"/>
    <parameter name="bc" class="java.lang.String"/>
    <parameter name="fournisseur" class="java.lang.String"/>
    <parameter name="affectation" class="java.lang.String"/>

    <detail>
        <band height="71">

            <!-- Optional border -->
            <rectangle>
                <reportElement x="0" y="0" width="108" height="71"/>
            </rectangle>

            <!-- ESTF -->
            <staticText>
                <reportElement x="0" y="2" width="108" height="14"/>
                <textElement textAlignment="Center">
                    <font fontName="Arial" size="12" isBold="true"/>                </textElement>
                <text><![CDATA[ESTF]]></text>
            </staticText>

            <!-- N°INV : inventaire/year -->
            <textField>
                <reportElement x="2" y="18" width="104" height="16"/>
                <textElement textAlignment="Center">
                    <font fontName="Arial" size="10" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[
                "N°INV : " + $P{inventoryNumber} + "/" + $P{year}
            ]]></textFieldExpression>
            </textField>

            <!-- BC : Fournisseur : Affectation -->
            <textField textAdjust="StretchHeight">
                <reportElement x="2" y="36" width="104" height="30"/>
                <textElement textAlignment="Left">
                    <font size="6"/>
                </textElement>
                <textFieldExpression><![CDATA[
                "BC : " + $P{bc}
                + "\nFournisseur : " + $P{fournisseur}
                + "\nAffectation : " + $P{affectation}
            ]]></textFieldExpression>
            </textField>

        </band>
    </detail>

</jasperReport>