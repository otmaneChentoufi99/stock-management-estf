<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
      fx:controller="ma.estf.magasiner.controllers.DashboardController"
      style="-fx-padding: 30px; -fx-background-color: white; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
      
    <Label text="Dashboard" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
    <Label text="Welcome to the stock management system." style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d;"/>
    
    <HBox spacing="20">
        <VBox style="-fx-background-color: #3498db; -fx-padding: 20px; -fx-border-radius: 8px; -fx-background-radius: 8px;" prefWidth="250">
            <Label text="Total Available Articles" style="-fx-text-fill: white; -fx-font-size: 16px;"/>
            <Label fx:id="totalArticlesLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox style="-fx-background-color: #e74c3c; -fx-padding: 20px; -fx-border-radius: 8px; -fx-background-radius: 8px;" prefWidth="250">
            <Label text="Damaged/Broken Stock" style="-fx-text-fill: white; -fx-font-size: 16px;"/>
            <Label fx:id="totalDamagedLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

    <Label text="Inventory Details" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 10px 0 0 0;"/>
    <TableView fx:id="inventoryTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colRef" text="Référence" prefWidth="120"/>
            <TableColumn fx:id="colName" text="Designation" prefWidth="250"/>
            <TableColumn fx:id="colType" text="Type" prefWidth="100"/>
            <TableColumn fx:id="colAvailable" text="Disponibles" prefWidth="100"/>
            <TableColumn fx:id="colDamaged" text="Endommagés" prefWidth="100"/>
        </columns>
    </TableView>
</VBox>
