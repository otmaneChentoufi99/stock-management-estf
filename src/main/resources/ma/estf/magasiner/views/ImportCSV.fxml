<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.*?>

<?import java.lang.String?>
<VBox spacing="20"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ma.estf.magasiner.controllers.ImportCSVController"
      style="-fx-padding: 30px;
             -fx-background-color: white;
             -fx-background-radius: 10px;
             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);">

    <Label text="Import Bon de Commande (Excel)"
           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <!-- ComboBox options -->
    <fx:define>
        <FXCollections fx:factory="observableArrayList" fx:id="typeOptions">
            <String fx:value="MATERIEL"/>
            <String fx:value="CONSOMMABLE"/>
        </FXCollections>
    </fx:define>

    <!-- Type -->
    <HBox spacing="10">
        <Label text="Type:"/>
        <ComboBox fx:id="typeComboBox" prefWidth="250">
            <items>
                <fx:reference source="typeOptions"/>
            </items>
        </ComboBox>
    </HBox>

    <!-- File -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <Button text="Select Excel File"
                onAction="#handleSelectFile"
                style="-fx-background-color: #3498db; -fx-text-fill: white;"/>

        <Label fx:id="selectedFileLabel"
               text="No file selected..."
               style="-fx-text-fill: gray;"/>
    </HBox>

    <Button text="Load File"
            onAction="#handleImport"
            style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"/>


    <Label fx:id="statusLabel" style="-fx-font-weight: bold;"/>

    <!-- Table -->
    <VBox fx:id="tableContainer"
          spacing="15"
          visible="false"
          managed="false">

        <Label text="Review Parsed Items"
               style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

        <TableView fx:id="articlesTable" prefHeight="250">
            <columns>
                <TableColumn fx:id="colDesignation" text="Désignation" prefWidth="300"/>
                <TableColumn fx:id="colQuantity" text="Quantité" prefWidth="100"/>
                <TableColumn fx:id="colNeedsInvNum" text="N° Inventaire ?" prefWidth="120"/>
                <TableColumn fx:id="colCategory" text="Catégorie" prefWidth="150"/>
            </columns>
        </TableView>

        <Button text="Confirm Import"
                onAction="#handleConfirmImport"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </VBox>

</VBox>