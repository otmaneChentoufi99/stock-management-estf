<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.lang.*?>
<?import javafx.collections.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
      fx:controller="ma.estf.magasiner.controllers.ImportCSVController" 
      style="-fx-padding: 30px; -fx-background-color: white; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
      
    <Label text="Import Bon de Commande (Excel)" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    
    <!-- Define the options for the ComboBox -->
    <fx:define>
        <javafx.collections.FXCollections fx:factory="observableArrayList" fx:id="typeOptions">
            <java.lang.String fx:value="MATERIEL"/>
            <java.lang.String fx:value="CONSOMMABLE"/>
        </javafx.collections.FXCollections>
    </fx:define>

    <GridPane hgap="15" vgap="15">
        <Label text="N° Bon Commande:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="numeroBCField" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="300" />
        
        <Label text="Service Demandeur:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="serviceDemandeurField" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="300"/>

        <Label text="Type de Bon Commande:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <ComboBox fx:id="typeComboBox" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="300">
            <items>
                <fx:reference source="typeOptions"/>
            </items>
        </ComboBox>
    </GridPane>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <Button text="Select Excel File" onAction="#handleSelectFile" style="-fx-base: #3498db; -fx-text-fill: white; -fx-padding: 8px 15px;"/>
        <Label fx:id="selectedFileLabel" text="No file selected..." style="-fx-text-fill: gray;"/>
    </HBox>
    
    <Button text="Load File" onAction="#handleImport" style="-fx-base: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px 20px;"/>
    
    <Label fx:id="statusLabel" text="" style="-fx-text-fill: green; -fx-font-weight: bold;"/>

    <VBox fx:id="tableContainer" spacing="15" visible="false" managed="false">
        <Label text="Review Parsed Items" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        <TableView fx:id="articlesTable" prefHeight="250">
            <columns>
                <TableColumn fx:id="colDesignation" text="Désignation" prefWidth="300"/>
                <TableColumn fx:id="colQuantity" text="Quantité" prefWidth="100"/>
                <TableColumn fx:id="colNeedsInvNum" text="N° Inventaire ?" prefWidth="120"/>
            </columns>
        </TableView>
        <Button fx:id="confirmImportBtn" text="Confirm Import" onAction="#handleConfirmImport" style="-fx-base: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px 20px;"/>
    </VBox>
</VBox>
