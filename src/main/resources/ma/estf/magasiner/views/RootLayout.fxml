<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
            fx:controller="ma.estf.magasiner.controllers.RootController" 
            prefHeight="768.0" prefWidth="1024.0">
    <left>
        <VBox spacing="15" style="-fx-background-color: #2c3e50; -fx-padding: 20px;" prefWidth="250">
            <Label text="ESTF Magasiner" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Separator />
            <Button text="Dashboard" onAction="#showDashboard" maxWidth="Infinity" style="-fx-base: #34495e; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 10px;"/>
            <Button text="Import CSV" onAction="#showImportCSV" maxWidth="Infinity" style="-fx-base: #34495e; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 10px;"/>
            <Button text="Bon Commande" onAction="#showBonCommandeList" maxWidth="Infinity" style="-fx-base: #34495e; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 10px;"/>
            <Button text="Articles" onAction="#showCart" maxWidth="Infinity" style="-fx-base: #34495e; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 10px;"/>
            <Button text="Affectations" onAction="#showAffectationList" maxWidth="Infinity" style="-fx-base: #34495e; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 10px;"/>
            <Button text="HR Details" onAction="#showHR" maxWidth="Infinity" style="-fx-base: #34495e; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 10px;"/>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #ecf0f1; -fx-padding: 20px;"/>
    </center>
</BorderPane>
