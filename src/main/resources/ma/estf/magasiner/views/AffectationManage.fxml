<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" prefWidth="900" prefHeight="700" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="ma.estf.magasiner.controllers.AffectationManageController"
      style="-fx-background-color: #f8f9fa;">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Header Section -->
    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label fx:id="titleLabel" text="Gestion de l'Affectation" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #2c3e50;"/>
            <HBox spacing="20">
                <Label fx:id="beneficiaryLabel" text="Bénéficiaire: " style="-fx-text-fill: #7f8c8d;"/>
                <Label fx:id="dateLabel" text="Date: " style="-fx-text-fill: #7f8c8d;"/>
            </HBox>
        </VBox>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Transférer Tout" onAction="#handleTransferAll" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button text="Retourner Tout" onAction="#handleReturnAll" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </HBox>
    </HBox>

    <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <!-- Left: Current Items -->
        <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 10;">
            <Label text="Articles de cette affectation" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colRef" text="Référence" prefWidth="90"/>
                    <TableColumn fx:id="colName" text="Désignation" prefWidth="180"/>
                    <TableColumn fx:id="colQuantity" text="Qté" prefWidth="50"/>
                    <TableColumn fx:id="colInventory" text="N° Inv" prefWidth="100"/>
                    <TableColumn fx:id="colCondition" text="État" prefWidth="70"/>
                    <TableColumn fx:id="colSelect" text="Action" prefWidth="80"/>
                </columns>
            </TableView>
        </VBox>

        <!-- Right: Selection for Actions -->
        <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 10;">
            <Label text="Sélection pour Transfert / Retour" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <TableView fx:id="selectionTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colSelName" text="Désignation" prefWidth="120"/>
                    <TableColumn fx:id="colSelQty" text="Qté" prefWidth="60"/>
                    <TableColumn fx:id="colSelCond" text="Nouvel État" prefWidth="100"/>
                    <TableColumn fx:id="colSelRemove" text="Action" prefWidth="60"/>
                </columns>
            </TableView>
            <Separator/>
            <VBox spacing="10">
                <Label text="Cible du Transfert (si applicable):" style="-fx-font-size: 11px;"/>
                <TextField fx:id="targetField" promptText="Nom ou Département"/>
                <HBox spacing="10" alignment="CENTER">
                    <Button text="Transférer" onAction="#handleBulkTransfer" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Button text="Retourner" onAction="#handleBulkReturn" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
        </VBox>
    </SplitPane>

</VBox>
